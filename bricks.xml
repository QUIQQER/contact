<?xml version="1.0" encoding="UTF-8"?>
<quiqqer>
    <bricks>
        <brick control="\QUI\Contact\CtaAction\Control">
            <title>
                <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.title"/>
            </title>
            <description>
                <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.description"/>
            </description>

            <settings>
                <setting name="formDesign" type="select">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.formDesign"/>
                    <option></option>
                    <option value="default">
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.formDesign.default"/>
                    </option>
                    <option value="grid">
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.formDesign.grid"/>
                    </option>
                    <option value="labelLeft">
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.formDesign.labelLeft"/>
                    </option>
                </setting>
                <setting name="recipient" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.recipient"/>
                </setting>
                <setting name="ctaDescription" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.ctaDescription"/>
                </setting>
                <setting name="logo" type="text" data-qui="controls/projects/project/media/Input">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.logo"/>
                </setting>

                <!-- buttons -->
                <setting name="whatsapp" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.whatsapp"/>
                    <description>
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.whatsapp.description"/>
                    </description>
                </setting>
                <setting name="whatsappLabel" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.whatsappLabel"/>
                    <description>
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.whatsappLabel.desc"/>
                    </description>
                </setting>
                <setting name="phone" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.phone"/>
                    <description>
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.phone.description"/>
                    </description>
                </setting>
                <setting name="phoneLabel" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.phoneLabel"/>
                    <description>
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.phoneLabel.desc"/>
                    </description>
                </setting>
                <setting name="email" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.email"/>
                    <description>
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.email.description"/>
                    </description>
                </setting>
                <setting name="emailLabel" type="text">
                    <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.emailLabel"/>
                    <description>
                        <locale group="quiqqer/contact" var="brick.control.ctaAction.setting.emailLabel.desc"/>
                    </description>
                </setting>
            </settings>
        </brick>
    </bricks>
</quiqqer>